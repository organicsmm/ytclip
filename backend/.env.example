# Supabase Configuration (obtained from Supabase Project settings)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=your-supabase-publishable-anon-key

# Modal endpoints (obtained after running `modal deploy` inside backend/modal_apps/)
MODAL_YT_URL=https://<workspace>--autocliper-yt-web.modal.run
MODAL_WHISPER_URL=https://<workspace>--autocliper-whisper-web.modal.run
MODAL_RENDER_URL=https://<workspace>--autocliper-render-web.modal.run

# Shared Bearer token for authenticating calls between FastAPI backend and Modal apps (generate a random string)
MODAL_AUTH_TOKEN=your-random-modal-auth-bearer-token

# Google Gemini API key (for Gemini 2.0 Flash clip selection)
GEMINI_API_KEY=your-google-gemini-api-key

# Internal pipeline signing key (generate a random 32-byte hex key)
INTERNAL_PIPELINE_SECRET=your-random-32-byte-hex-key

# Paddle Webhook configuration
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_PRICE_STARTER=your-paddle-price-starter-id
PADDLE_PRICE_PRO=your-paddle-price-pro-id

# App Environment
FRONTEND_ORIGIN=http://localhost:5173
PORT=8080
